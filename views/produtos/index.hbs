<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Lista de Produtos - ElectroStore</h2>
        {{#if user}}
            {{#if (eq user.perfil "admin")}}
                <a href="/produtos/novo" class="btn btn-primary">Cadastrar Novo Produto</a>
            {{else}}
                {{#if (eq user.perfil "lojista")}}
                    <a href="/produtos/novo" class="btn btn-primary">Cadastrar Novo Produto</a>
                {{/if}}
            {{/if}}
        {{/if}}
    </div>

    <div class="mb-4">
        <span class="fw-bold me-2">Filtrar por Categoria:</span>
        <a href="/produtos" class="btn btn-sm btn-outline-dark me-1">Todos</a>
        <a href="/produtos?categoria=1" class="btn btn-sm btn-outline-primary me-1">Informática</a>
        <a href="/produtos?categoria=2" class="btn btn-sm btn-outline-primary me-1">Eletrodomésticos</a>
        <a href="/produtos?categoria=3" class="btn btn-sm btn-outline-primary">Smartphones</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Descrição</th>
                <th>Cadastrado Por</th>
            </tr>
        </thead>
        <tbody>
            {{#each produtos}}
            <tr>
                <td>{{this.id}}</td>
                <td>{{this.nome}}</td>
                <td>R$ {{this.preco}}</td>
                <td>{{this.quantidade}} un</td>
                <td>{{this.descricao}}</td>
                <td>{{this.usuario.nome}}</td>
            </tr>
            {{else}}
            <tr>
                <td colspan="6" class="text-center text-muted">Nenhum produto cadastrado até o momento.</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>