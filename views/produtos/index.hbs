<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Lista de Produtos - ElectroStore</h2>
        <a href="/produtos/novo" class="btn btn-primary">Cadastrar Novo Produto</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Descrição</th>
                <th>Cadastrado Por</th>
            </tr>
        </thead>
        <tbody>
            {{#each produtos}}
            <tr>
                <td>{{this.id}}</td>
                <td>{{this.nome}}</td>
                <td>R$ {{this.preco}}</td>
                <td>{{this.estoque}} un</td>
                <td>{{this.descricao}}</td>
                <td>{{this.usuario.nome}}</td>
            </tr>
            {{else}}
            <tr>
                <td colspan="6" class="text-center text-muted">Nenhum produto cadastrado até o momento.</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>