<!DOCTYPE html>
<html>

<head>
  <title>ElectroStore</title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

  <nav class="navbar navbar-expand-lg bg-primary ">
    <div class="container">
      <a class="navbar-brand text-light fw-bold" href="/">
        🏬 ElectroStore
      </a>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link text-light" href="/historia">
              🕒 Nossa História
            </a>
          </li>
        </ul>

        <ul class="navbar-nav ms-auto">
          {{#if user}}
          <li class="nav-item">
            <span class="nav-link text-light me-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                class="bi bi-person-fill" viewBox="0 0 20 20">
                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
              </svg> <strong>{{user.nome}}</strong></span>
          </li>
          <li class="nav-item">
            <a class="btn btn-primary btn-sm mt-1" href="/users/logout">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                class="bi bi-door-closed" viewBox="0 0 16 16">
                <path d="M3 2a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v13h1.5a.5.5 0 0 1 0 1h-13a.5.5 0 0 1 0-1H3zm1 13h8V2H4z" />
                <path d="M9 9a1 1 0 1 0 2 0 1 1 0 0 0-2 0" />
              </svg>
              Sair</a>
          </li>
          {{else}}
          <li class="nav-item ">
            <a class="nav-link text-light me-2" href="/users/login">
              ⊦ Login
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link fw-bold text-light" href="/users/cadastro">
              👤+ Cadastro Usuário
            </a>
          </li>
          {{/if}}
        </ul>
      </div>
    </div>
  </nav>

  {{{body}}}

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>