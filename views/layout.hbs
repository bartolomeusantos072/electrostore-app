<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <title>ElectroStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold text-white" href="/">ElectroStore</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link text-white" href="/">Início</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="/produtos">Produtos</a>
            </li>
            
            {{#if user}}
              {{#if (eq user.perfil "admin")}}
                <li class="nav-item"><a class="nav-link text-white fw-bold" href="/produtos/novo">Painel Cadastrar</a></li>
              {{else}}
                {{#if (eq user.perfil "lojista")}}
                  <li class="nav-item"><a class="nav-link text-white fw-bold" href="/produtos/novo">Painel Cadastrar</a></li>
                {{/if}}
              {{/if}}
            {{/if}}
          </ul>

          <div class="d-flex align-items-center text-white">
            {{#if user}}
              <span class="me-3">Olá, <strong>{{user.nome}}</strong> ({{user.perfil}})</span>
              <a href="/users/logout" class="btn btn-outline-light btn-sm">Sair</a>
            {{else}}
              <a href="/users/login" class="btn btn-outline-light btn-sm me-2">Login</a>
              <a href="/users/cadastro" class="btn btn-light btn-sm text-primary fw-bold">Cadastrar</a>
            {{/if}}
          </div>
        </div>
      </div>
    </nav>

    <main class="container">
      {{{body}}}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>